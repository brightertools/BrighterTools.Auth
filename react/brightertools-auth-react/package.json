{
  "name": "brightertools-auth-react",
  "version": "1.0.0",
  "description": "React companion components, hooks, API adapters, and localization helpers for BrighterTools.Auth.",
  "license": "MIT-0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrighterTools/BrighterTools.Auth.git",
    "directory": "react/brightertools-auth-react"
  },
  "homepage": "https://github.com/BrighterTools/BrighterTools.Auth#readme",
  "bugs": {
    "url": "https://github.com/BrighterTools/BrighterTools.Auth/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.26.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./recaptcha": {
      "types": "./dist/recaptcha.d.ts",
      "default": "./dist/recaptcha.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
